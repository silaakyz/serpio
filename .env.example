# ─────────────────────────────────────────────────────────────
# Serpio — Environment Variables
# cp .env.example .env.local  (web app)
# cp .env.example .env        (worker)
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://serpio:serpio_dev@localhost:5432/serpio_dev"

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ── Auth.js v5 ────────────────────────────────────────────────
AUTH_SECRET=""                    # openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# OAuth Providers (FAZ 2)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── OpenAI / GPT-4 ────────────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_ORG_ID=""

# ── Stripe (FAZ 3) ────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Vercel (web deploy) ───────────────────────────────────────
VERCEL_URL=""

# ── Worker Config ─────────────────────────────────────────────
WORKER_CONCURRENCY="5"
WORKER_MAX_JOBS_PER_WORKER="10"

# ── Playwright ────────────────────────────────────────────────
PLAYWRIGHT_BROWSERS_PATH=""
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD="1"

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL="info"                  # debug | info | warn | error
