# ─── Database (Neon.tech) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/serpio?sslmode=require"

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
REDIS_URL="rediss://default:xxx@xxx.upstash.io:6379"

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# openssl rand -base64 32 ile oluştur
AUTH_SECRET="change-me-with-openssl-rand-base64-32"
AUTH_URL="https://serpio.app"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
AUTH_GOOGLE_ID="xxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxx"

# ─── AI Provider ─────────────────────────────────────────────────────────────
AI_PROVIDER="gemini"
GEMINI_API_KEY="xxx"
# OPENAI_API_KEY="sk-xxx"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@serpio.app"
ADMIN_SETUP_SECRET="strong-random-value"
